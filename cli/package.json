{
    "name": "daxiapi-cli",
    "version": "3.0.0",
    "description": "虾皮金融数据API命令行工具，提供个股、选股、基本面等金融数据的查询和分析功能。",
    "bin": {
        "daxiapi": "./dist/index.js",
        "dxp": "./dist/index.js"
    },
    "scripts": {
        "build": "webpack --config webpack.config.js",
        "prepack": "npm run build",
        "test": "node --test test/*.test.js",
        "test:coverage": "node --test --experimental-test-coverage --test-coverage-branches=80 --test-coverage-functions=80 --test-coverage-lines=80 test/*.test.js"
    },
    "keywords": [
        "stock",
        "api",
        "daxiapi",
        "cli",
        "finance"
    ],
    "author": "daxiapi.com",
    "license": "MIT",
    "dependencies": {
        "@ksky521/html-picker": "^1.0.0",
        "@toon-format/toon": "^2.3.0",
        "axios": "^1.6.0",
        "chalk": "^4.1.2",
        "commander": "^11.1.0",
        "conf": "^10.2.0",
        "iconv-lite": "^0.5.0"
    },
    "devDependencies": {
        "webpack": "^5.108.3",
        "webpack-cli": "^5.1.4"
    },
    "engines": {
        "node": ">=14.0.0"
    },
    "files": [
        "dist",
        "README.md"
    ]
}
